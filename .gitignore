# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
conda-meta/

# Jupyter
.ipynb_checkpoints/

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/

# OS files
.DS_Store
Thumbs.db

# IDE/editor
.vscode/
.idea/

# Logs
*.log

# Project data
data/raw/*
data/processed/*
data/*.h5ad
!data/raw/.gitkeep
!data/processed/.gitkeep

# Results (generated outputs are usually ignored;
# selectively add important files with: git add -f <file>)
results/tables/*
results/metrics/*
!results/tables/.gitkeep
!results/metrics/.gitkeep

# Figures (generated outputs are usually ignored;
# selectively add important files with: git add -f <file>)
# results/project_summary.md is committed as a human-authored summary
figures/*.png
!figures/.gitkeep